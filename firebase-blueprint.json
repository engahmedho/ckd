{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "CKD prediction assessment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "inputs": { "type": "object" },
        "result": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "inputs", "result", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Historical assessments"
    }
  }
}
